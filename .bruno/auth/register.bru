meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{API_URL}}/register
  body: json
  auth: inherit
}

body:json {
  {
    "user_name": "{{USERNAME}}",
    "last_name": "Turing",
    "first_name": "Alan",
    "sector": 4,
    "email": "{{USER_EMAIL}}",
    "password": "{{USER_PASSWORD}}",
    "password_confirmation": "{{USER_PASSWORD}}"
  }
}
